# Copy to .env in this folder (repo root). Backend loads ../../.env from backend/src.

NODE_ENV=development

# API server (default 3001 — must match frontend VITE_API_URL / Vite proxy)
BACKEND_PORT=3001

# CORS: single origin or comma-separated list
# FRONTEND_URL=http://localhost:5173
# ALLOWED_ORIGINS=http://localhost:5173

# Database: sqlite (default, zero-config) or mysql
DB_DIALECT=sqlite

# MySQL — only when DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=onestep_db

# Admin login (POST /api/auth/admin-login) — change in production
# ADMIN_EMAIL=admin@onestep.com
# ADMIN_PASSWORD=Admin@123

# Firebase Admin (token verification)
# FIREBASE_PROJECT_ID=your-project-id

# Admin JWT (survives server restarts — set a long random string in production)
# ADMIN_JWT_SECRET=

# Razorpay (India — online payments)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Email (order confirmations — optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# STORE_DISPLAY_NAME=OneStep Hub
# GST_DISPLAY_TEXT=Prices inclusive of GST where applicable

# Sequelize sync — use with care (schema migrations preferred for production)
# SYNC_ALTER=false
