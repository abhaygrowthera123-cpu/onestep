NODE_ENV=production
PORT=3001
BACKEND_PORT=3001
SERVE_FRONTEND=true

# App URL (replace with your public domain)
FRONTEND_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com

# Database (used by app + MySQL service)
DB_DIALECT=mysql
DB_HOST=mysql
DB_PORT=3306
DB_NAME=onestep_db
DB_USER=onestep_user
DB_PASSWORD=change_me_db_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# Admin credentials
ADMIN_EMAIL=admin@onestep.com
ADMIN_PASSWORD=change_me_admin_password
ADMIN_JWT_SECRET=change_me_long_random_secret

# Firebase / payments
FIREBASE_PROJECT_ID=your-firebase-project-id
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxx

# Optional
STORE_DISPLAY_NAME=OneStep Hub
GST_DISPLAY_TEXT=Inclusive of all taxes
SYNC_ALTER=false
VITE_GOOGLE_MAPS_KEY=
